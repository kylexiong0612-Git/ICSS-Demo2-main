<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.icss.mapper.CustomerMapper">

    <resultMap id="customerResultMap" type="com.icss.model.Customer">
        <id     property="id"        column="id"/>
        <result property="name"      column="name"/>
        <result property="phone"     column="phone"/>
        <result property="idNumber"  column="id_number"/>
        <result property="tier"      column="tier"/>
        <result property="agentId"   column="agent_id"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <resultMap id="agentResultMap" type="com.icss.model.Agent">
        <id     property="id"        column="id"/>
        <result property="name"      column="name"/>
        <result property="code"      column="code"/>
        <result property="phone"     column="phone"/>
        <result property="branch"    column="branch"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <resultMap id="policyResultMap" type="com.icss.model.Policy">
        <id     property="id"         column="id"/>
        <result property="customerId" column="customer_id"/>
        <result property="name"       column="name"/>
        <result property="status"     column="status"/>
        <result property="premium"    column="premium"/>
        <result property="startDate"  column="start_date"/>
        <result property="endDate"    column="end_date"/>
        <result property="createdAt"  column="created_at"/>
    </resultMap>

    <select id="selectById" resultMap="customerResultMap">
        SELECT * FROM customer WHERE id = #{id}
    </select>

    <select id="selectAgentById" resultMap="agentResultMap">
        SELECT * FROM agent WHERE id = #{id}
    </select>

    <select id="selectPoliciesByCustomerId" resultMap="policyResultMap">
        SELECT * FROM policy WHERE customer_id = #{customerId} ORDER BY created_at DESC
    </select>

</mapper>
